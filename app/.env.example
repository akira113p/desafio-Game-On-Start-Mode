# ==============================================
# Game On: Start Mode - Variaveis de Ambiente
# ==============================================
# Copie este arquivo para .env.local (local) ou
# configure no painel da Vercel (producao).
# ==============================================

# --- Groq API (Chatbot + Motor de Onboarding) ---
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# --- Google OAuth (Login + Calendar) ---
# Obtenha em: https://console.cloud.google.com/apis/credentials
# Tipo: OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth.js ---
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=

# NEXTAUTH_URL (opcional):
#   - Local: http://localhost:3000
#   - Vercel: NAO precisa definir (a Vercel resolve automaticamente)
#   - Dominio customizado: https://seudominio.com.br
# NEXTAUTH_URL=http://localhost:3000
